{
  "info": {
    "name": "CNPM2 Hotel API (QLKS)",
    "description": "Collection khớp backend hiện tại. baseUrl = http://localhost:8080\n\nTài khoản seed (DataInitializer): admin/admin123, owner/owner123, user/user123",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "token", "value": "" }
  ],
  "item": [
    {
      "name": "Health & ping",
      "item": [
        {
          "name": "GET /api/health",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/api/health"
          }
        },
        {
          "name": "GET /actuator/health",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/actuator/health"
          }
        },
        {
          "name": "GET /public/ping",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/public/ping"
          }
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "POST /auth/login (ADMIN)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"admin123\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          }
        },
        {
          "name": "POST /auth/login (USER)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"user\",\n  \"password\": \"user123\"\n}"
            },
            "url": "{{baseUrl}}/auth/login"
          }
        },
        {
          "name": "POST /auth/register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"newuser\",\n  \"password\": \"pass12345\",\n  \"email\": \"new@example.com\",\n  \"role\": \"USER\"\n}"
            },
            "url": "{{baseUrl}}/auth/register"
          }
        }
      ]
    },
    {
      "name": "Public — tìm phòng",
      "item": [
        {
          "name": "GET /public/rooms/available",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/public/rooms/available?checkIn=2026-04-10&checkOut=2026-04-12&guests=2"
          }
        }
      ]
    },
    {
      "name": "Rooms (ADMIN / OWNER)",
      "item": [
        {
          "name": "GET /rooms",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/rooms"
          }
        }
      ]
    },
    {
      "name": "Booking & payment (USER)",
      "item": [
        {
          "name": "POST /user/bookings — tạo booking",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"roomId\": 1,\n  \"checkIn\": \"2026-04-10\",\n  \"checkOut\": \"2026-04-12\",\n  \"guests\": 2\n}"
            },
            "url": "{{baseUrl}}/user/bookings"
          }
        },
        {
          "name": "GET /user/bookings — lịch sử",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/user/bookings"
          }
        },
        {
          "name": "GET /payments/{id}",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/payments/1"
          }
        },
        {
          "name": "POST /payments/{id}/confirm — mock thanh toán",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"success\": true\n}"
            },
            "url": "{{baseUrl}}/payments/1/confirm"
          }
        }
      ]
    },
    {
      "name": "Owner — duyệt booking",
      "item": [
        {
          "name": "GET /owner/bookings",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/owner/bookings"
          }
        },
        {
          "name": "POST /bookings/{id}/approve",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "POST",
            "header": [],
            "url": "{{baseUrl}}/bookings/1/approve"
          }
        },
        {
          "name": "POST /bookings/{id}/reject",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "POST",
            "header": [],
            "url": "{{baseUrl}}/bookings/1/reject"
          }
        }
      ]
    },
    {
      "name": "Profile",
      "item": [
        {
          "name": "GET /me",
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
            },
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/me"
          }
        }
      ]
    }
  ]
}
